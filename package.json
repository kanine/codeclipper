{
  "name": "codeclipper",
  "publisher": "kanine",
  "displayName": "CodeClipper",
  "description": "Quickly copy the current filename and selected line numbers to the clipboard (e.g., versions.js line 22-23) via the right-click context menu.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git@github.com:kanine/codeclipper.git"
  },
  "bugs": {
    "url": "https://github.com/kanine/codeclipper/issues"
  },
  "homepage": "https://github.com/kanine/codeclipper#readme",
  "engines": {
    "vscode": "^1.118.0"
  },
  "files": [
    "out/**",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:copy-reference.copyLineRef"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-reference.copyLineRef",
        "title": "Copy File and Line Reference"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorTextFocus && editorHasSelection",
          "command": "copy-reference.copyLineRef",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:local": "vsce package --out codeclipper.vsix",
    "install:local": "code --install-extension codeclipper.vsix --force",
    "deploy:local": "npm run compile && npm run package:local && npm run install:local"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
